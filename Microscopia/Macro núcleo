dir = getDirectory("Choose a folder");
list = getFileList(dir);

for (i = 0; i < list.length; i++) {

    open(dir + list[i]);

    run("16-bit");
    setThreshold(15, 6255);
    run("Convert to Mask");
    run("Fill Holes");
    run("Watershed");
    run("Erode");
    run("Analyze Particles...", "size=40-Infinity pixel show=Outlines summarize");
	close("*");
}
